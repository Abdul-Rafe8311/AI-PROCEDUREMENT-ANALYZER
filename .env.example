# ─────────────────────────────────────────────────────────────
# AI Procurement Analyzer — Environment Configuration
# Copy this file to `.env` and fill in real values.
# ─────────────────────────────────────────────────────────────

# ── App ──
NODE_ENV=development
API_PORT=4000
WEB_PORT=3000
# Public URL the browser uses to reach the API
NEXT_PUBLIC_API_URL=http://localhost:4000

# ── Database (Supabase Postgres) ──
# From Supabase: Project Settings → Database → Connection string
#
# DATABASE_URL = Transaction pooler (Supavisor), port 6543 — used at runtime.
#   Must include ?pgbouncer=true (add &connection_limit=1 for serverless).
# DIRECT_URL   = Direct/session connection, port 5432 — used by prisma migrate / db push.
#
# Replace [PROJECT-REF], [PASSWORD], and [REGION] with your project's values.
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
DIRECT_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres

# ── JWT ──
JWT_ACCESS_SECRET=change_me_access_secret_at_least_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_at_least_32_chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
# Used to sign password-reset tokens
JWT_RESET_SECRET=change_me_reset_secret_at_least_32_chars
JWT_RESET_EXPIRES=30m

# ── OpenAI ──
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Web app: anonymous /workspace (apps/web) ──
# Supabase (Project Settings → API). Without these, /workspace runs in demo
# mode (no persistence). Browser-exposed, so use the *anon* key only.
NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT-REF].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
# ── LLM providers (apps/web, server-side secrets) ──
# CHAT + DEEP-DOCUMENT ANSWERS run on Anthropic Claude. REQUIRED for AI chat and
# deep-search synthesis; without it those degrade to computed/extract answers
# with a visible notice (never sample data).
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
# Model for chat + deep-document answers (optional; defaults to claude-sonnet-4-6).
ANTHROPIC_CHAT_MODEL=claude-sonnet-4-6
# Model for reading SCANNED PDFs and IMAGE uploads via Claude vision (optional;
# defaults to claude-sonnet-4-6). ANTHROPIC_API_KEY above powers this too.
ANTHROPIC_VISION_MODEL=claude-sonnet-4-6
#
# EXTRACTION of DIGITAL-TEXT PDFs/DOCX still runs on Groq (cheap/fast). Keep
# GROQ_API_KEY set for text uploads to be parsed. Scanned/image uploads use
# Claude vision (ANTHROPIC_API_KEY) instead. Reserved for a future move of text
# extraction onto a cheaper Claude model: ANTHROPIC_EXTRACTION_MODEL.
GROQ_API_KEY=gsk_your-groq-key
GROQ_MODEL=llama-3.3-70b-versatile

# ── Storage (Supabase Storage) ──
# Server-side only. SUPABASE_SERVICE_ROLE_KEY is REQUIRED for bucket/storage
# operations — the anon key cannot create buckets. The API fails fast on boot
# if URL or service-role key is missing. NEVER expose the service-role key to
# the browser. The bucket is created PRIVATE automatically on startup.
SUPABASE_URL=https://[PROJECT-REF].supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_STORAGE_BUCKET=quotations

# ── Rate limiting ──
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=120

# ── CORS ──
CORS_ORIGIN=http://localhost:3000
