# ─────────────────────────────────────────────────────────────
# AI Procurement Analyzer — Environment Configuration
# Copy this file to `.env` and fill in real values.
# ─────────────────────────────────────────────────────────────

# ── App ──
NODE_ENV=development
API_PORT=4000
WEB_PORT=3000
# Public URL the browser uses to reach the API
NEXT_PUBLIC_API_URL=http://localhost:4000

# ── Database (Supabase Postgres) ──
# From Supabase: Project Settings → Database → Connection string
#
# DATABASE_URL = Transaction pooler (Supavisor), port 6543 — used at runtime.
#   Must include ?pgbouncer=true (add &connection_limit=1 for serverless).
# DIRECT_URL   = Direct/session connection, port 5432 — used by prisma migrate / db push.
#
# Replace [PROJECT-REF], [PASSWORD], and [REGION] with your project's values.
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
DIRECT_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres

# ── JWT ──
JWT_ACCESS_SECRET=change_me_access_secret_at_least_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_at_least_32_chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
# Used to sign password-reset tokens
JWT_RESET_SECRET=change_me_reset_secret_at_least_32_chars
JWT_RESET_EXPIRES=30m

# ── OpenAI ──
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Web app: anonymous /workspace (apps/web) ──
# Supabase (Project Settings → API). Without these, /workspace runs in demo
# mode (no persistence). Browser-exposed, so use the *anon* key only.
NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT-REF].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
# OPENAI_API_KEY above also powers the /workspace chat route (server-side).

# ── S3-compatible storage (AWS S3 / MinIO) ──
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=quotations
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
# true when using path-style endpoints like MinIO
S3_FORCE_PATH_STYLE=true
# Public endpoint used to build presigned/download URLs (host-reachable)
S3_PUBLIC_ENDPOINT=http://localhost:9000

# ── Rate limiting ──
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=120

# ── CORS ──
CORS_ORIGIN=http://localhost:3000
